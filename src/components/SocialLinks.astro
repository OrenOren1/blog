---
import { SITE } from "@lib/site";

const links = [
  { href: SITE.social.github, label: "GitHub", id: "github", external: true },
  { href: SITE.social.gitlab, label: "GitLab", id: "gitlab", external: true },
  { href: SITE.social.medium, label: "Medium", id: "medium", external: true },
  { href: SITE.social.linkedin, label: "LinkedIn", id: "linkedin", external: true },
  { href: `mailto:${SITE.social.email}`, label: "Email", id: "email", external: false },
  { href: SITE.social.rss, label: "RSS", id: "rss", external: false },
];
---

<ul class="social-links" role="list">
  {links.map((link) => (
    <li>
      <a
        href={link.href}
        aria-label={link.label}
        rel={link.external ? "me noopener noreferrer" : "alternate"}
        target={link.external ? "_blank" : undefined}
        class={`${link.id}-icon`}
      >
        {link.id === "github" && (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M12 1.5c-5.53 0-10 4.52-10 10.1 0 4.46 2.87 8.24 6.84 9.58.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.7-2.78.61-3.37-1.36-3.37-1.36-.45-1.18-1.11-1.5-1.11-1.5-.9-.62.07-.61.07-.61 1 .07 1.53 1.04 1.53 1.04.89 1.54 2.34 1.09 2.91.83.09-.66.35-1.09.64-1.34-2.22-.26-4.55-1.13-4.55-5 0-1.11.39-2.01 1.03-2.72-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.04a9.27 9.27 0 0 1 5 0c1.9-1.31 2.74-1.04 2.74-1.04.56 1.41.21 2.45.1 2.71.64.71 1.03 1.61 1.03 2.72 0 3.88-2.34 4.74-4.57 5 .36.32.69.94.69 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49 3.96-1.34 6.83-5.12 6.83-9.58 0-5.58-4.47-10.1-10-10.1Z" />
          </svg>
        )}
        {link.id === "gitlab" && (
          <svg viewBox="0 0 512 512" aria-hidden="true">
            <path d="M503.5 204.6L502.8 202.8L433.1 21.02C431.7 17.45 429.2 14.43 425.9 12.38C423.5 10.83 420.8 9.865 417.9 9.57C415 9.275 412.2 9.653 409.5 10.68C406.8 11.7 404.4 13.34 402.4 15.46C400.5 17.58 399.1 20.13 398.3 22.9L351.3 166.9H160.8L113.7 22.9C112.9 20.13 111.5 17.59 109.6 15.47C107.6 13.35 105.2 11.72 102.5 10.7C99.86 9.675 96.98 9.295 94.12 9.587C91.26 9.878 88.51 10.83 86.08 12.38C82.84 14.43 80.33 17.45 78.92 21.02L9.267 202.8L8.543 204.6C-1.484 230.8-2.72 259.6 5.023 286.6C12.77 313.5 29.07 337.3 51.47 354.2L51.74 354.4L52.33 354.8L158.3 434.3L210.9 474L242.9 498.2C246.6 500.1 251.2 502.5 255.9 502.5C260.6 502.5 265.2 500.1 268.9 498.2L300.9 474L353.5 434.3L460.2 354.4L460.5 354.1C482.9 337.2 499.2 313.5 506.1 286.6C514.7 259.6 513.5 230.8 503.5 204.6z"/>
          </svg>
        )}
        {link.id === "medium" && (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4.5 7.19c0-.35-.1-.69-.3-.98L2.16 3.38V3h6.74l5.21 11.44L18.7 3H24v.38l-1.69 1.62a1 1 0 0 0-.32.76v11.88a1 1 0 0 0 .32.76l1.63 1.62V20H16v-.38l1.75-1.7c.17-.17.17-.22.17-.47V8.65l-4.87 11.3h-.66L6.81 8.65v7.67c-.05.34.07.69.3.94l2.27 2.77v.38H2v-.38l2.27-2.77c.23-.25.35-.6.26-.94V7.19Z" />
          </svg>
        )}
        {link.id === "linkedin" && (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4.98 3.5a2.49 2.49 0 1 1 0 4.98 2.49 2.49 0 0 1 0-4.98ZM2.4 9h5.17v12.5H2.4V9Zm7.67 0h4.95v1.71h.07c.69-1.24 2.37-2.54 4.87-2.54 5.21 0 6.17 3.43 6.17 7.89V21.5h-5.16v-6.89c0-1.64-.03-3.75-2.29-3.75-2.3 0-2.65 1.79-2.65 3.63V21.5H10.1V9Z" />
          </svg>
        )}
        {link.id === "rss" && (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 16a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm-4-7a1 1 0 0 1 1-1c10.48 0 19 8.52 19 19a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1c0-7.18-5.82-13-13-13a1 1 0 0 1-1-1V9Zm0-6a1 1 0 0 1 1-1C13.6 2 22 10.4 22 21a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1c0-7.72-6.28-14-14-14a1 1 0 0 1-1-1V3Z" />
          </svg>
        )}
        {link.id === "email" && (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.43 4.5a3 3 0 0 1-3.14 0L1.5 8.67ZM12 20a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm0-12a2 2 0 0 1 2 2v1.5l-6 3.2-6-3.2V10a2 2 0 0 1 2-2h8Z" />
          </svg>
        )}
      </a>
    </li>
  ))}
</ul>
