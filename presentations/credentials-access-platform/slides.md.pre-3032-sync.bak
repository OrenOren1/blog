```mermaid
graph LR
    subgraph S["👥 SUBJECTS"]
        direction TB
        H_RO["👤 Engineer<br/>(standing)"]
        H_JIT["👤 Engineer<br/>(JIT RW)"]
        H_OC["📟 On-call"]
