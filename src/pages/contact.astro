---
import BaseLayout from "@layouts/BaseLayout.astro";
import { SITE } from "@lib/site";
---

<BaseLayout
  title="Contact"
  description={`Contact ${SITE.author} — platform engineering, DevOps, and consulting.`}
  canonicalPath="/contact"
>
  <section class="contact-hero wrap">
    <div>
      <p class="reading-eyebrow">Get in touch</p>
      <h1>Contact</h1>
      <p class="contact-copy">
        Reach out for consulting, workshops, or collaboration. You can use the form below or
        email me directly.
      </p>
      <p class="contact-copy">
        <a href={SITE.social.resume} class="cta secondary" target="_blank" rel="noopener noreferrer">
          View resume →
        </a>
      </p>
    </div>
  </section>

  <section class="contact-section wrap">
    <form
      class="contact-form"
      action={`mailto:${SITE.social.email}`}
      method="post"
      encType="text/plain"
    >
      <div class="form-grid">
        <label>
          <span>First name</span>
          <input type="text" name="first_name" required autocomplete="given-name" />
        </label>
        <label>
          <span>Last name</span>
          <input type="text" name="last_name" required autocomplete="family-name" />
        </label>
        <label>
          <span>Company</span>
          <input type="text" name="company" autocomplete="organization" />
        </label>
        <label>
          <span>Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
      </div>

      <label class="contact-description">
        <span>How can I help?</span>
        <textarea
          name="message"
          rows="6"
          maxLength="500"
          required
          placeholder="Briefly describe what you’re looking for (500 characters max)"
        ></textarea>
      </label>

      <div class="contact-actions">
        <button type="submit" class="cta">Send email →</button>
        <p class="contact-footnote">
          Submitting opens your mail client with the details pre-filled to{" "}
          <a href={`mailto:${SITE.social.email}`}>{SITE.social.email}</a>. Review before sending.
        </p>
      </div>
    </form>
  </section>
</BaseLayout>
